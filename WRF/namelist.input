&time_control
--------------------------------------------------------------------------------
-- 模拟时长设置 (run_* 与 end_* 同时存在时，end_* 优先级更高)
--------------------------------------------------------------------------------
 run_days          = 0,          ! 模拟天数
 run_hours         = 10,         ! 模拟小时数
 run_minutes       = 0,          ! 模拟分钟数
 run_seconds       = 0,          ! 模拟秒数
--------------------------------------------------------------------------------
-- 模拟起止时间 (必须与 namelist.wps 及驱动数据时间完全一致)
--------------------------------------------------------------------------------
 start_year        = 2022,       ! 开始年份
 start_month       = 11,         ! 开始月份
 start_day         = 25,         ! 开始日期
 start_hour        = 18,         ! 开始时刻 (UTC)
 start_minute      = 00,         ! 开始分钟
 start_second      = 00,         ! 开始秒
 end_year          = 2022,       ! 结束年份
 end_month         = 12,         ! 结束月份
 end_day           = 05,         ! 结束日期
 end_hour          = 18,         ! 结束时刻 (UTC)
--------------------------------------------------------------------------------
-- 输入与输出控制
--------------------------------------------------------------------------------
 interval_seconds  = 10800,      ! 边界条件更新间隔 (秒)，需与驱动数据时间分辨率一致 (如 3 小时=10800)
 input_from_file   = .true.,     ! 初始场来源 (.true.=从 wrfinput 文件读取; .false.=理想化模拟)
 history_interval  = 180,        ! 历史输出间隔 (分钟)，即 wrfout 文件的时间分辨率 (180=3 小时)
 frames_per_outfile = 1,         ! 每个输出文件包含的时间帧数 (1=每帧一个文件; >1=多帧合并)
 restart           = .false.,    ! 是否重启模拟 (.true.=从 wrfrst 续跑; .false.=冷启动)
 restart_interval  = 1440,       ! 重启文件输出间隔 (分钟)，用于断点续跑 (1440=24 小时)
--------------------------------------------------------------------------------
-- 文件格式控制 (1=Binary, 2=NetCDF, 3=GRIB1, 4=GRIB2)
--------------------------------------------------------------------------------
 io_form_history   = 2,          ! 历史输出文件 (wrfout) 格式
 io_form_restart   = 2,          ! 重启文件 (wrfrst) 格式
 io_form_input     = 2,          ! 初始场输入文件 (wrfinput) 格式
 io_form_boundary  = 2,          ! 边界场输入文件 (wrfbdy) 格式
 debug_level       = 0           ! 调试信息级别 (0=关闭; >0 输出详细调试日志)
/

&domains
--------------------------------------------------------------------------------
-- 时间步长与嵌套域数量
--------------------------------------------------------------------------------
 time_step         = 72,         ! 主时间步长 (秒)。经验公式：dx(km) * 6。12km 分辨率建议 72 秒
 time_step_fract_num = 0,        ! 时间步长分数部分分子 (通常设为 0)
 time_step_fract_den = 1,        ! 时间步长分数部分分母 (通常设为 1)
 max_dom           = 1,          ! 嵌套域总数 (1=单域; >1=多重嵌套)
--------------------------------------------------------------------------------
-- 网格维度 (必须与 namelist.wps 中的 geogrid 设置完全一致)
--------------------------------------------------------------------------------
 e_we              = 121,        ! 西 - 东方向网格数 (实际计算格点数为 e_we-1)
 e_sn              = 101,        ! 南 - 北方向网格数 (实际计算格点数为 e_sn-1)
 e_vert            = 35,         ! 垂直方向层数 (常用 35 层，高层模式可设 50+)
--------------------------------------------------------------------------------
-- 垂直坐标与驱动数据层级
--------------------------------------------------------------------------------
 p_top_requested   = 5000,       ! 模式顶气压 (Pa)，5000=50hPa
 num_metgrid_levels = 34,        ! 驱动数据 (met_em) 的垂直层数，需与实际文件一致
 num_metgrid_soil_levels = 4,    ! 驱动数据的土壤层数，通常为 4
--------------------------------------------------------------------------------
-- 网格间距 (必须与 namelist.wps 中的 geogrid 设置完全一致)
--------------------------------------------------------------------------------
 dx                = 12000,      ! 东西方向网格间距 (米)
 dy                = 12000,      ! 南北方向网格间距 (米)
--------------------------------------------------------------------------------
-- 嵌套关系配置 (单域模拟时保持默认即可)
--------------------------------------------------------------------------------
 grid_id           = 1,          ! 当前域编号 (1 为最外层)
 parent_id         = 1,          ! 父域编号 (1 表示无父域)
 i_parent_start    = 1,          ! 子域左下角在父域中的 i 索引 (从 1 开始)
 j_parent_start    = 1,          ! 子域左下角在父域中的 j 索引 (从 1 开始)
 parent_grid_ratio = 1,          ! 父域与当前域网格比 (1=同分辨率; 嵌套通常为 3 或 5)
 parent_time_step_ratio = 1,     ! 父域与当前域时间步长比 (通常保持 1)
 feedback          = 1,          ! 嵌套反馈方式 (0=单向; 1=双向，子域结果反馈给父域)
 smooth_option     = 0           ! 嵌套边界平滑选项 (0=无; 1=平滑)
/

&physics
--------------------------------------------------------------------------------
-- 微物理与辐射方案
--------------------------------------------------------------------------------
 mp_physics        = 8,          ! 微物理方案 (3=WSM6; 8=Thompson 推荐; 10=双参数)
 ra_lw_physics     = 4,          ! 长波辐射方案 (1=RRTM; 4=RRTMG 推荐)
 ra_sw_physics     = 4,          ! 短波辐射方案 (1=杜德海亚; 4=RRTMG 推荐)
 radt              = 30,         ! 辐射方案调用间隔 (分钟)
--------------------------------------------------------------------------------
-- 陆面与边界层方案
--------------------------------------------------------------------------------
 sf_sfclay_physics = 2,          ! 近地面层方案 (1=Monin-Obukhov; 2=Jiménez 推荐)
 sf_surface_physics = 2,         ! 陆面过程方案 (1=简单; 2=Noah 推荐; 4=Noah-MP)
 bl_pbl_physics    = 2,          ! 边界层方案 (1=YSU 推荐; 2=MYJ; 11=MYNN)
 bldt              = 0,          ! 边界层方案调用间隔 (0=每步计算; >0=间隔分钟数)
--------------------------------------------------------------------------------
-- 积云参数化方案
--------------------------------------------------------------------------------
 cu_physics        = 1,          ! 积云方案 (0=关闭; 1=Kain-Fritsch 推荐)
                                   ! 注意：分辨率<=3km 时建议设为 0 (显式对流)
 cudt              = 5,          ! 积云方案调用间隔 (分钟)
--------------------------------------------------------------------------------
-- 其他物理选项
--------------------------------------------------------------------------------
 isfflx            = 1,          ! 地表通量输出开关 (1=输出; 0=不输出)
 ifsnow            = 0,          ! 雪盖方案开关 (0=关闭; 1=启用)
 icloud            = 1,          ! 云辐射反馈开关 (0=关闭; 1=启用)
 surface_input_source = 1,       ! 地表数据源 (1=使用 geogrid 生成的静态数据)
 num_soil_layers   = 4,          ! 土壤层数 (需与陆面方案匹配，Noah 通常为 4)
 sf_urban_physics  = 0           ! 城市冠层方案 (0=无; 1=单层; 2=多层)
/

&fdda
--------------------------------------------------------------------------------
-- 四维资料同化 (FDDA) 配置
--------------------------------------------------------------------------------
! 此模块通常为空，如需开启同化需添加 grid_fdda, gfdda_interval 等参数
/

&dynamics
--------------------------------------------------------------------------------
-- 动力框架与垂直坐标
--------------------------------------------------------------------------------
 hybrid_opt        = 2,          ! 垂直坐标类型 (2=地形跟随混合坐标 推荐)
 w_damping         = 0,          ! 垂直速度阻尼 (0=关闭; 1=顶层阻尼)
--------------------------------------------------------------------------------
-- 扩散方案
--------------------------------------------------------------------------------
 diff_opt          = 1,          ! 水平扩散方案 (1=显式 推荐; 2=隐式)
 km_opt            = 4,          ! 水平扩散系数计算 (4=基于变形率 推荐)
 diff_6th_opt      = 0,          ! 六阶扩散选项 (0=关闭; 1=启用，高分辨率推荐)
 diff_6th_factor   = 0.12,       ! 六阶扩散系数
--------------------------------------------------------------------------------
-- 阻尼层设置 (用于吸收顶层重力波反射)
--------------------------------------------------------------------------------
 base_temp         = 290.,       ! 参考温度 (K)
 damp_opt          = 0,          ! 顶层阻尼方案 (0=关闭; 3=启用 推荐)
 zdamp             = 5000.,      ! 阻尼层起始高度 (米)
 dampcoef          = 0.2,        ! 阻尼系数
--------------------------------------------------------------------------------
-- 平流与非静力平衡
--------------------------------------------------------------------------------
 khdif             = 0,          ! 水平扩散系数 (通常设 0，由 km_opt 自动计算)
 kvdif             = 0,          ! 垂直扩散系数 (通常设 0)
 non_hydrostatic   = .true.,     ! 非静力平衡开关 (.true.=启用; 高分辨率必须启用)
 moist_adv_opt     = 1,          ! 水汽平流方案 (1=三阶; 2=五阶)
 scalar_adv_opt    = 1           ! 标量平流方案 (1=三阶; 2=五阶)
/

&bdy_control
--------------------------------------------------------------------------------
-- 边界条件控制
--------------------------------------------------------------------------------
 spec_bdy_width    = 5,          ! 侧边界松弛区宽度 (网格数)，通常设为 5
 specified         = .true.,     ! 边界条件类型 (.true.=时变边界; .false.=固定边界)
 nested            = .false.     ! 是否为嵌套域 (.false.=最外层; .true.=嵌套域)
/

&grib2
--------------------------------------------------------------------------------
-- GRIB2 输出配置
--------------------------------------------------------------------------------
! 此模块通常为空，如需输出 GRIB2 格式需添加相关参数
/

&namelist_quilt
--------------------------------------------------------------------------------
-- IO 任务分配 (高性能计算优化)
--------------------------------------------------------------------------------
 nio_tasks_per_group = 0,        ! 每组 IO 任务数 (0=所有任务参与 IO)
 nio_groups          = 1         ! IO 任务组数
/