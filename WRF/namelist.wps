&share
--------------------------------------------------------------------------------
-- 模式核心与嵌套域设置
--------------------------------------------------------------------------------
 wrf_core          = 'ARW',      ! WRF 核心模式 ('ARW'=高级研究模式; 'NMM'=非静力中尺度模式)
 max_dom           = 1,          ! 嵌套域总数 (1=单域; >1=多重嵌套，需与 namelist.input 一致)
--------------------------------------------------------------------------------
-- 模拟时间设置 (必须与驱动数据时间范围匹配)
--------------------------------------------------------------------------------
 start_date        = '2022-11-25_18:00:00',  ! 模拟开始时间 (格式：YYYY-MM-DD_HH:MM:SS)
 end_date          = '2022-12-05_18:00:00',  ! 模拟结束时间 (格式同上)
 interval_seconds  = 10800,      ! 驱动数据时间间隔 (秒)，需与 GFS/ERA5 等数据输出间隔一致 (10800=3 小时)
--------------------------------------------------------------------------------
-- 输出格式控制
--------------------------------------------------------------------------------
 io_form_geogrid   = 2,          ! geogrid 输出格式 (1=Binary; 2=NetCDF 推荐; 3=GRIB1; 4=GRIB2)
/

&geogrid
--------------------------------------------------------------------------------
-- 嵌套关系定义 (单域模拟时保持默认)
--------------------------------------------------------------------------------
 parent_id         = 1,          ! 父域编号 (1 表示最外层域，无父域)
 parent_grid_ratio = 1,          ! 父域与当前域网格比 (1=同分辨率; 嵌套域通常为 3 或 5)
 i_parent_start    = 1,          ! 子域左下角在父域中的 i 索引 (列号，从 1 开始)
 j_parent_start    = 1,          ! 子域左下角在父域中的 j 索引 (行号，从 1 开始)
--------------------------------------------------------------------------------
-- 网格维度与分辨率 (必须与 namelist.input 中的 &domains 完全一致)
--------------------------------------------------------------------------------
 e_we              = 121,        ! 西 - 东方向网格数 (实际计算格点数为 e_we-1)
 e_sn              = 101,        ! 南 - 北方向网格数 (实际计算格点数为 e_sn-1)
 geog_data_res     = 'default',  ! 地理数据分辨率 ('default'=默认; 也可指定 '30s', '5m' 等)
 dx                = 12000,      ! 东西方向网格间距 (米)，决定模式水平分辨率
 dy                = 12000,      ! 南北方向网格间距 (米)，通常与 dx 相同
--------------------------------------------------------------------------------
-- 地图投影设置 (关键参数，决定模拟区域位置)
--------------------------------------------------------------------------------
 map_proj          = 'lambert',  ! 投影方式 ('lambert'=兰伯特; 'mercator'=墨卡托; 'polar'=极地)
 ref_lat           = 37.5,       ! 参考点纬度 (投影中心纬度，决定模拟区域中心位置)
 ref_lon           = 118.0,      ! 参考点经度 (投影中心经度，与 ref_lat 共同定义域中心)
 truelat1          = 30.0,       ! 第一标准纬线 (兰伯特投影中无长度变形的纬线，通常取区域南部)
 truelat2          = 60.0,       ! 第二标准纬线 (兰伯特投影中无长度变形的纬线，通常取区域北部)
 stand_lon         = 118.0,      ! 标准经线 (投影中无长度变形的经线，通常与 ref_lon 一致)
--------------------------------------------------------------------------------
-- 地理数据路径
--------------------------------------------------------------------------------
 geog_data_path    = '/home/zy/WRF/DATA/WPS_GEOG/WPS_GEOG',  ! 静态地理数据目录路径
/

&ungrib
--------------------------------------------------------------------------------
-- 驱动数据解包设置
--------------------------------------------------------------------------------
 out_format        = 'WPS',      ! 输出格式 ('WPS'=标准格式，供 metgrid 读取)
 prefix            = 'FILE',     ! 输出文件前缀 (生成文件名为 FILE:YYYY-MM-DD_HH)
/

&metgrid
--------------------------------------------------------------------------------
-- 气象场插值设置
--------------------------------------------------------------------------------
 fg_name           = 'FILE',     ! 输入文件前缀 (需与 ungrib 的 prefix 一致)
 io_form_metgrid   = 2,          ! metgrid 输出格式 (1=Binary; 2=NetCDF 推荐; 3=GRIB1; 4=GRIB2)
/